<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<TabPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0"
         prefWidth="600.0" tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/8"
         xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="at.htlkaindorf.exa_201_inventorymanagement.controller.AppController">
    <Tab text="RECORD">
        <VBox prefHeight="200.0" prefWidth="100.0">
            <GridPane alignment="TOP_RIGHT" hgap="10.0" vgap="20.0">
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                </rowConstraints>
                <VBox.margin>
                    <Insets/>
                </VBox.margin>
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </padding>
                <Label alignment="CENTER_RIGHT" contentDisplay="RIGHT" text="CODE" textAlignment="RIGHT"/>
                <Label text="NAME" textAlignment="RIGHT" GridPane.rowIndex="1"/>
                <Label text="TYPE" GridPane.rowIndex="2"/>
                <Label text="AMOUNT" GridPane.rowIndex="3"/>
                <TextField fx:id="tfCode" GridPane.columnIndex="1"/>
                <TextField fx:id="tfName" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <TextField fx:id="tfAmount" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                <ChoiceBox fx:id="cbType" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1"
                           GridPane.rowIndex="2"/>
            </GridPane>
            <ListView fx:id="lvItems" prefHeight="200.0" prefWidth="200.0">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </padding>
                <VBox.margin>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </VBox.margin>
            </ListView>
            <HBox alignment="CENTER" spacing="100.0">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </padding>
                <Button fx:id="btAddItem" mnemonicParsing="false" text="ADD"/>
                <Button fx:id="btDeleteItem" mnemonicParsing="false" text="DELETE"/>
            </HBox>
        </VBox>
    </Tab>
    <Tab text="TYPES">
        <VBox prefHeight="200.0" prefWidth="100.0">
            <HBox alignment="CENTER" spacing="100.0">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </padding>
                <Button fx:id="btAddType" mnemonicParsing="false" text="ADD"/>
                <Button fx:id="btDeleteType" mnemonicParsing="false" text="DELETE"/>
            </HBox>
            <ListView fx:id="lvTypes">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </padding>
                <VBox.margin>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </VBox.margin>
            </ListView>
        </VBox>
    </Tab>
    <Tab text="SEARCH &amp; EDIT">
        <VBox prefHeight="200.0" prefWidth="100.0">
            <TextField fx:id="tfSearch" promptText="Search Text">
                <VBox.margin>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </VBox.margin>
            </TextField>
            <ListView fx:id="lvResult">
                <VBox.margin>
                    <Insets bottom="10.0" left="10.0" right="10.0"/>
                </VBox.margin>
            </ListView>
        </VBox>
    </Tab>
</TabPane>
